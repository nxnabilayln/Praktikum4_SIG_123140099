SELECT
    w.nama AS wilayah,
    COUNT(f.id) AS jumlah_fasilitas,
    COALESCE(
        STRING_AGG(f.nama, ', '), '-'
    ) AS daftar_fasilitas, 
    ROUND(
        ST_Area(w.geom::geography)::numeric / 1000000, 2
    ) AS luas_km2
FROM public.wilayah w
LEFT JOIN public.fasilitas_publik f
    ON ST_Contains(w.geom, f.geom)
GROUP BY w.id, w.nama, w.geom
ORDER BY jumlah_fasilitas DESC;
